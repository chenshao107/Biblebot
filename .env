# === 向量数据库配置 (Qdrant) ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=kb_hybrid

# === LLM 配置 (用于查询改写等) ===
LLM_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXX
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# === 词嵌入配置 (Embedding) ===
# 如果开启 USE_EMBEDDING_API=True，请配置独立的 API Key 和 URL
USE_EMBEDDING_API=True
EMBEDDING_API_KEY=
EMBEDDING_API_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIM=4096
EMBEDDING_API_TIMEOUT=120
EMBEDDING_API_MAX_RETRIES=3
EMBEDDING_API_RETRY_DELAY=2

# === 重排配置 (Rerank) ===
# 注意：rerank 现在总是启用（只要检索结果超过 top_k 就会自动触发）
RERANK_API_KEY=
RERANK_API_URL=https://api.siliconflow.cn/v1/rerank
RERANK_MODEL_NAME=Qwen/Qwen3-Reranker-8B

# === 路径配置 ===
DATA_RAW_DIR=data/raw
DATA_CANONICAL_DIR=data/canonical_md
DATA_CHUNKS_DIR=data/chunks
DATA_EMBEDDINGS_DIR=data/embeddings

# === 中间文件保存配置 ===
# 是否保存数据处理流程的中间文件（转换后的 MD、切块 JSON、嵌入元数据等），用于调优参考
SAVE_INTERMEDIATE_FILES=True

# === Agent 配置 ===
AGENT_MAX_ITERATIONS=15
BASH_TOOL_TIMEOUT=30
PYTHON_TOOL_TIMEOUT=30
# BASH_WORK_DIR=data/raw  # 可选，默认使用 DATA_RAW_DIR

# === 工具安全控制（调试期可禁用）===
# 注意：默认禁用黑白名单，方便调试 Agent Prompt
# 生产环境请设置为 true 启用安全检查
ENABLE_BASH_WHITELIST=false
ENABLE_PYTHON_RESTRICTIONS=false

# === LLM 调试配置 ===
# 开启后会保存每次 LLM API 调用的完整输入输出到日志文件
DEBUG_LLM_API=true
DEBUG_LLM_LOG_DIR=logs/llm

# === Docker 沙箱配置（推荐）===
# 使用 Docker 沙箱可以完全释放 Bash 和 Python 工具的能力，无需黑白名单限制
# 同时保证宿主机安全，知识库只读，工作目录隔离
USE_DOCKER_SANDBOX=false
DOCKER_SANDBOX_IMAGE=bibobot-sandbox:latest
DOCKER_MEMORY_LIMIT=512m
DOCKER_CPU_QUOTA=100000
DOCKER_TIMEOUT=60

# === 网络搜索工具配置 (可选) ===
# 推荐使用 Tavily（专为 LLM 优化，返回摘要）：https://tavily.com/
# TAVILY_API_KEY=your_tavily_api_key_here
#
# 备选：Serper（Google 搜索）
# SERPER_API_KEY=your_serper_api_key_here
