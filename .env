# === 向量数据库配置 (Qdrant) ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=kb_hybrid

# === 基础 API 配置 (通用于 LLM, Embedding, Rerank) ===
# 填入你的硅基流动、DeepSeek 或 OpenAI 的 API Key
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# === 词嵌入配置 (Embedding) ===
# 如果开启 USE_EMBEDDING_API=True，EMBEDDING_MODEL_NAME 请填写云端模型名 (如 BAAI/bge-m3)
USE_EMBEDDING_API=False
EMBEDDING_API_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL_NAME=BAAI/bge-base-zh-v1.5

# === 重排配置 (Rerank) ===
# 如果开启 USE_RERANK_API=True，RERANK_MODEL_NAME 请填写云端模型名 (如 BAAI/bge-reranker-v2-m3)
USE_RERANK_API=False
RERANK_API_URL=https://api.siliconflow.cn/v1/rerank
RERANK_MODEL_NAME=ms-marco-MiniLM-L-6-v2

# === 路径配置 ===
DATA_RAW_DIR=data/raw
DATA_CANONICAL_DIR=data/canonical_md
