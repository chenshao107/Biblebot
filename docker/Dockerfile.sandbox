# Biblebot Sandbox - Claude CLI Agent 探索环境
# 为 Claude CLI 提供隔离的 Bash 和 Python 执行环境

FROM python:3.10-slim-bookworm

LABEL maintainer="Biblebot Team"
LABEL description="Exploration sandbox for Claude CLI Agent — Bash + Python + rich toolset"

# 环境变量
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV DEBIAN_FRONTEND=noninteractive
ENV WORKSPACE=/workspace

# 系统工具 — 供 Claude CLI Agent 探索知识库使用
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    coreutils \
    curl \
    wget \
    ca-certificates \
    git \
    build-essential \
    gcc \
    g++ \
    make \
    cmake \
    vim \
    nano \
    less \
    grep \
    ripgrep \
    fd-find \
    tree \
    jq \
    yq \
    bat \
    fzf \
    silversearcher-ag \
    file \
    unzip \
    p7zip-full \
    pandoc \
    poppler-utils \
    net-tools \
    iputils-ping \
    dnsutils \
    sqlite3 \
    bc \
    htop \
    neofetch \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# fd 软链接
RUN ln -s $(which fdfind) /usr/local/bin/fd 2>/dev/null || true

# Python 包 — 供 Claude CLI Agent 数据分析使用
RUN pip install --no-cache-dir \
    numpy \
    pandas \
    matplotlib \
    requests \
    beautifulsoup4 \
    lxml \
    pyyaml \
    python-dateutil \
    scipy \
    scikit-learn \
    openpyxl \
    pillow \
    rich \
    tqdm \
    httpx \
    aiohttp

# 工作目录
# /workspace/data/canonical_md - 知识库（只读映射）
# /workspace/work - 工作目录（可读写）
# /workspace/temp - 临时目录
RUN mkdir -p \
    ${WORKSPACE}/data/canonical_md \
    ${WORKSPACE}/work \
    ${WORKSPACE}/temp \
    && chmod 755 ${WORKSPACE}/data/canonical_md \
    && chmod 777 ${WORKSPACE}/work \
    && chmod 777 ${WORKSPACE}/temp

WORKDIR ${WORKSPACE}

# 非 root 用户
RUN groupadd -r agent && useradd -r -g agent -d ${WORKSPACE} -s /bin/bash agent \
    && chown -R agent:agent ${WORKSPACE}/work ${WORKSPACE}/temp

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD python -c "print('healthy')" || exit 1

CMD ["tail", "-f", "/dev/null"]
