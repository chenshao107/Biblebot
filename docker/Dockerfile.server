# Biblebot - RAG 服务镜像（Claude CLI 适配版）
# Agent Runtime 由 Claude CLI 提供，本服务仅负责 RAG 检索

FROM python:3.10-slim-bookworm

LABEL maintainer="Biblebot Team"
LABEL description="Biblebot RAG Server — serves knowledge retrieval for Claude CLI Agent"

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV DEBIAN_FRONTEND=noninteractive

# 系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    g++ \
    libmagic1 \
    curl \
    git \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

WORKDIR /app

# 依赖安装
# 国内默认用清华镜像加速，海外可通过 --build-arg PIP_INDEX=https://pypi.org/simple 覆盖
ARG PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
COPY requirements.txt .
RUN pip install --no-cache-dir -i ${PIP_INDEX} --trusted-host pypi.tuna.tsinghua.edu.cn -r requirements.txt

# 应用代码
COPY app/ ./app/
COPY scripts/ ./scripts/

# 目录
RUN mkdir -p \
    /app/data/raw \
    /app/data/work \
    /app/data/canonical_md \
    /app/data/chunks \
    /app/data/embeddings

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
