# ============================================================
# Prompt Patch 模板文件
# 使用方法：复制本文件并重命名为 patches.yaml，然后按需修改
#   cp prompts_override/patches.yaml.example prompts_override/patches.yaml
#
# 支持的操作（op）：
#   after        在目标节点末尾追加内容（最常用）
#   before       在目标节点开头插入内容
#   replace      完整替换目标节点内容
#   append_line  追加单行内容
#
# 可用节点（target）：
#   base             角色定义
#   tools            工具列表
#   strategy         工具策略与使用建议
#   knowledge_scope  知识库覆盖范围说明
#   answer_format    回答规范
# ============================================================

# ── 示例一：追加公司环境规则（最典型用法）──────────────────────────────────
# - op: after
#   target: strategy
#   content: |
#     企业环境附加规则：
#     - 优先搜索本地知识库，不要使用 web_search
#     - 涉及保密项目代码时，禁止调用任何外网工具

# ── 示例二：替换角色定义（限定业务范围）──────────────────────────────────
# - op: replace
#   target: base
#   content: |
#     你是 XX 公司内部知识助手，只回答与公司业务、产品、技术文档相关的问题。
#     对于超出范围的问题，请礼貌告知用户"这超出了我的服务范围"。

# ── 示例三：在知识库范围说明前插入提示 ────────────────────────────────────
# - op: before
#   target: knowledge_scope
#   content: |
#     注意：当前知识库仅包含内部审核后的资料，版本可能滞后，请以实际部署版本为准。

# ── 示例四：追加回答格式要求 ───────────────────────────────────────────────
# - op: after
#   target: answer_format
#   content: |
#     额外要求：
#     - 所有回答必须使用中文
#     - 涉及命令行操作时，必须给出完整可执行命令

# ── 示例五：工具开关（禁用某类工具）──────────────────────────────────────
# - op: append_line
#   target: strategy
#   content: "- 禁止使用 run_python，如需数据处理请改用 run_bash"
